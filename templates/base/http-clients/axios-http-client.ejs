/**
 * 终极网络层实现 - 采用 uni.request 绕过所有 Axios 适配器 Bug
 */
export type QueryParamsType = Record<string | number, any>;

export enum ContentType {
  Json = "application/json",
  FormData = "multipart/form-data",
  UrlEncoded = "application/x-www-form-urlencoded",
  Text = "text/plain",
}

export interface FullRequestParams {
  secure?: boolean;
  path: string;
  method?: string;
  type?: ContentType;
  query?: QueryParamsType;
  format?: string;
  body?: unknown;
  headers?: Record<string, string>;
}

export type RequestParams = Omit<FullRequestParams, "body" | "method" | "query" | "path">;

export interface ApiConfig<SecurityDataType = unknown> {
  baseURL?: string;
  headers?: Record<string, string>;
}

export class HttpClient<SecurityDataType = unknown> {
  private baseUrl: string;
  private instanceHeaders: Record<string, string>;
  public interceptors: {
    request: Array<(config: FullRequestParams) => FullRequestParams | Promise<FullRequestParams>>;
    response: Array<(res: any) => any>;
  };

  constructor(config: ApiConfig<SecurityDataType> = {}) {
    this.baseUrl = config.baseURL || "<%~ apiConfig.baseUrl %>";
    this.instanceHeaders = config.headers || {};
    this.interceptors = {
      request: [],
      response: []
    };
  }

  public async request<T = any, _E = any>(params: FullRequestParams): Promise<T> {
    // 1. 执行请求拦截器
    let config = { ...params };
    for (const interceptor of this.interceptors.request) {
      config = await interceptor(config);
    }

    // 2. 构造完整 URL
    let finalBaseUrl = (this as any).realBaseUrl || this.baseUrl || "";
    let fullUrl = config.path;
    if (!config.path.startsWith('http')) {
      fullUrl = finalBaseUrl.replace(/\/$/, '') + '/' + config.path.replace(/^\//, '');
    }

    // 3. 准备原生请求参数
    const method = (config.method || "GET").toUpperCase() as any;
    
    return new Promise((resolve, reject) => {
      console.log(`[Native Request] ${method} ${fullUrl}`, config.query || "");
      
      uni.request({
        url: fullUrl,
        method: method,
        data: method === "GET" ? config.query : (config.body as any),
        header: {
          ...this.instanceHeaders,
          ...config.headers
        },
        timeout: 15000,
        success: (res: any) => {
          console.log(`[Native Response] Success: ${fullUrl}`, res.data);
          
          // 执行响应拦截器逻辑
          let finalData = res;
          for (const interceptor of this.interceptors.response) {
            finalData = interceptor(finalData);
          }
          
          resolve(finalData.data as T);
        },
        fail: (err) => {
          console.error(`[Native Response] Failed: ${fullUrl}`, err);
          reject(err);
        }
      });
    });
  }
}
